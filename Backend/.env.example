PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/staybyhour
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
CLIENT_URL=http://localhost:5173
ADMIN_PANEL_URL=http://localhost:5175
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="StayByHour <no-reply@staybyhour.com>"

# Razorpay — leave blank to run in mock-payment mode (auto-confirms bookings without a gateway)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Firebase Admin — used for both push notifications (FCM) and verifying
# Google sign-in ID tokens. Leave blank to disable both; in-app + realtime
# notifications and phone/email login still work without it.
# Paste the full service-account JSON as a single-line string, OR give a file path.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=

# Cron jobs
JOBS_ENABLED=true
CRON_HOLD_EXPIRY=*/1 * * * *
CRON_ACTIVATE_BOOKINGS=*/1 * * * *
CRON_CHECKOUT_REMINDER=*/1 * * * *
CRON_OVERDUE_PENALTY=*/5 * * * *
CRON_NO_SHOW=*/5 * * * *
CRON_SLOT_CLEANUP=*/10 * * * *

# Business rules (minutes / rupees)
HOLD_EXPIRY_MINUTES=10
CHECKOUT_GRACE_MINUTES=30
CHECKOUT_REMINDER_MINUTES=15
OVERDUE_PENALTY_PER_HOUR=150

# Check-in / check-out access codes
ACCESS_CODE_LENGTH=8
ACCESS_CODE_EXPIRY_HOURS=48
